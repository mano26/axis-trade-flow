# =============================================================================
# AXIS Trade Flow — Environment Variables
# =============================================================================
# Copy this file to .env and fill in values for local development.
# Railway sets these via the dashboard (Settings → Variables).
# NEVER commit the actual .env file to version control.
# =============================================================================

# --- Flask Core ---
FLASK_APP=wsgi.py
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-string-in-production

# --- Database ---
# Local development: PostgreSQL running on localhost
DATABASE_URL=postgresql://axis:axis@localhost:5432/axis_trade_flow

# --- Railway ---
# Railway injects DATABASE_URL automatically when you add the PostgreSQL plugin.
# No need to set it manually in Railway's environment.

# --- Rithmic API (STUBBED — fill when integrating) ---
# RITHMIC_URI=
# RITHMIC_USER=
# RITHMIC_PASSWORD=
# RITHMIC_SYSTEM_NAME=Dorman Trading
# RITHMIC_GATEWAY=Chicago

# --- Application ---
# Maximum ticket number before rollover (default 9999, matching VBA tool)
MAX_TICKET_NUMBER=9999
